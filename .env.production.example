# Reference list of every env var the stack needs. In Coolify, paste these
# into the "Environment Variables" panel of the Compose deployment (or the
# matching App if you split into per-service deployments). Build-time vars
# (the WEB_VITE_* / DASH_VITE_* / VITE_GOOGLE_* group) must also be added
# under "Build Arguments" because Vite bakes them into the bundle.
#
# Domains + HTTPS are handled by Coolify, not configured here.

# ============================================================================
# Database & cache (shared by auth + graphql)
# ============================================================================
DATABASE_URL=postgres://user:pass@38.54.93.72:5432/cam-travel
# Redis is provided externally — point this at your existing instance.
REDIS_URL=redis://default:replace_me@your-redis-host:6379/0

# ============================================================================
# Auth service
# ============================================================================
# Generate with:  openssl rand -base64 32
BETTER_AUTH_SECRET=replace_me
# Auth's own public URL — the browser calls auth directly at this host. The
# Google OAuth redirect is computed as `${BETTER_AUTH_URL}/api/auth/callback/
# google` and must be registered in Google Cloud Console for this exact URL.
BETTER_AUTH_URL=https://auth.example.com
# Scopes the session cookie to a parent domain so auth, gateway, web, and
# dashboard subdomains all see it. Set to the parent with a leading dot,
# e.g. ".example.com".
AUTH_COOKIE_DOMAIN=.example.com
# Google OAuth (Console → APIs & Services → Credentials).
# Authorized redirect URI must include: https://auth.example.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Bootstrap admin user — seeded by the auth SeedService on app start.
# If the user already exists, it's promoted to role=admin. Password must
# be at least 8 chars. Rotate after first login.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin

# ============================================================================
# CORS — comma-separated allowed origins for the browser-facing services.
# Auth + api-gateway both validate Origin against this list.
# ============================================================================
CORS_ORIGINS=https://example.com,https://admin.example.com

# ============================================================================
# GraphQL service (MinIO + Google Places)
# ============================================================================
MINIO_ENDPOINT=minio-dev.rikrey.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=cam-travel
GOOGLE_PLACES_API_KEY=
# Used to build photo proxy URLs returned by GraphQL.
PUBLIC_API_URL=https://api.example.com

# ============================================================================
# Frontend build args (baked into the bundle at docker build time)
# ============================================================================
# Each backend service has its own public subdomain. The browser calls each
# directly. VITE_AUTH_URL must point at the auth service (NOT the gateway) —
# routing auth through the gateway proxy corrupted POST bodies.
WEB_VITE_API_URL=https://api.example.com
WEB_VITE_AUTH_URL=https://auth.example.com
WEB_VITE_GRAPHQL_HTTP_URL=https://api.example.com/graphql/v1
VITE_GOOGLE_CLIENT_ID=
VITE_PUBLIC_MAP_KEY=

# dashboard — admin panel.
# WS_URL points at the graphql service directly because the api-gateway only
# proxies HTTP /graphql/v1 (over the TCP microservice transport), not
# WebSocket upgrades.
DASH_VITE_API_URL=https://api.example.com
DASH_VITE_AUTH_URL=https://auth.example.com
DASH_VITE_GRAPHQL_WS_URL=wss://graphql.example.com/graphql/v1
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_ID=

# ============================================================================
# Coolify magic vars — make each backend service publicly routable.
# Coolify reads SERVICE_FQDN_<SVC> and injects Traefik labels for that
# container's exposed port. Only set the ones you want public.
# ============================================================================
SERVICE_URL_AUTH=https://auth.example.com
SERVICE_FQDN_AUTH=auth.example.com
SERVICE_URL_API_GATEWAY=https://api.example.com
SERVICE_FQDN_API_GATEWAY=api.example.com
SERVICE_URL_WEB=https://example.com
SERVICE_FQDN_WEB=example.com
SERVICE_URL_DASHBOARD=https://admin.example.com
SERVICE_FQDN_DASHBOARD=admin.example.com
# Only needed if dashboard uses WS subscriptions against graphql directly.
SERVICE_URL_GRAPHQL=https://graphql.example.com
SERVICE_FQDN_GRAPHQL=graphql.example.com
