DATABASE_URL=postgres://postgres:postgres@localhost:5432/monobase
REDIS_URL=redis://localhost:6379
NODE_ENV=development
PORT=3002
GRAPHQL_TCP_HOST=127.0.0.1
GRAPHQL_TCP_PORT=4002
# Comma-separated allowed origins for browser CORS (subscriptions over WS hit
# /graphql directly). Required in prod. Defaults to the dev frontends.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# MinIO (S3-compatible) — used by the files upload feature
MINIO_ENDPOINT=minio-fwok40cksg8ssc0owsgwwc8k.threecup.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=F6P5ad88UM9Gphx4CHc4
MINIO_SECRET_KEY=37vvLzP3lR5Os6ndp6f1NFC0e9O0hUTWXLYRDQtz
MINIO_BUCKET=monobase

# Google Places API v1 — used to enrich attractions with rating/photos.
# Server-side only; never expose to the browser.
GOOGLE_PLACES_API_KEY=

# Gemini via Vercel AI SDK — used by the logged-in AI travel planner.
# Rotate any key that was pasted into chat or logs before deploying.
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Public-facing base URL of the API gateway. Used to build photo proxy URLs
# returned in GraphQL responses (so the dashboard doesn't need to know the
# gateway origin separately). Defaults to http://localhost:3000 in dev.
PUBLIC_API_URL=http://localhost:3000
