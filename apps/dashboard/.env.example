VITE_API_URL=http://localhost:3000
VITE_AUTH_URL=http://localhost:3001
VITE_GRAPHQL_WS_URL=ws://localhost:3002/graphql/v1

# Google Maps JavaScript API key. Restrict to HTTP referrers in dev.
VITE_GOOGLE_MAPS_API_KEY=
# Optional Google Maps `mapId` for vector/styled map. Falls back to DEMO_MAP_ID.
VITE_GOOGLE_MAPS_ID=

# Dev-only credentials pre-filled on the login form. Only used when running
# in dev mode; production builds always render an empty form.
VITE_DEV_LOGIN_EMAIL=
VITE_DEV_LOGIN_PASSWORD=
